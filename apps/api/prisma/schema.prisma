generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  inventory_manager
  purchasing_staff
  kitchen_manager
  analyst
}

enum MovementType {
  purchase
  usage
  adjustment
  waste
  return
}

enum ReferenceType {
  purchase_order
  waste_log
  manual_adjustment
  pos_consumption
  simulation
}

enum WasteReason {
  expiration
  spoilage
  overproduction
  damage
  quality_issue
  other
}

enum PurchaseOrderStatus {
  draft
  submitted
  approved
  ordered
  received
  cancelled
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum ScenarioType {
  occupancy_change
  lead_time_change
  seasonal_shift
  supplier_delay
  demand_spike
}

model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(120)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  role          UserRole
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  @@map("users")
}

model Hotel {
  id                String              @id @default(uuid())
  name              String              @db.VarChar(150)
  location          String              @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamptz
  updated_at        DateTime            @updatedAt @db.Timestamptz
  suppliers         Supplier[]
  skus              Sku[]
  menu_items        MenuItem[]
  pos_transactions  PosTransaction[]
  occupancy_records OccupancyRecord[]
  purchase_orders   PurchaseOrder[]
  simulation_runs   SimulationRun[]

  @@map("hotels")
}

model Supplier {
  id                     String             @id @default(uuid())
  hotel_id               String
  name                   String             @db.VarChar(150)
  contact_name           String?            @db.VarChar(120)
  contact_email          String?            @db.VarChar(255)
  contact_phone          String?            @db.VarChar(30)
  default_lead_time_days Int
  created_at             DateTime           @default(now()) @db.Timestamptz
  updated_at             DateTime           @updatedAt @db.Timestamptz
  hotel                  Hotel              @relation(fields: [hotel_id], references: [id])
  skus                   Sku[]
  purchase_orders        PurchaseOrder[]
  supplier_lead_times    SupplierLeadTime[]

  @@map("suppliers")
}

model Sku {
  id                             String                        @id @default(uuid())
  hotel_id                       String
  supplier_id                    String
  sku_code                       String                        @db.VarChar(50)
  name                           String                        @db.VarChar(150)
  category                       String?                       @db.VarChar(100)
  unit                           String                        @db.VarChar(30)
  unit_cost                      Decimal                       @db.Decimal(12, 2)
  holding_cost_per_unit          Decimal                       @db.Decimal(12, 2)
  order_cost                     Decimal                       @db.Decimal(12, 2)
  shelf_life_days                Int
  safety_stock                   Decimal                       @db.Decimal(12, 3)
  minimum_stock                  Decimal                       @db.Decimal(12, 3)
  is_active                      Boolean                       @default(true)
  created_at                     DateTime                      @default(now()) @db.Timestamptz
  updated_at                     DateTime                      @updatedAt @db.Timestamptz
  hotel                          Hotel                         @relation(fields: [hotel_id], references: [id])
  supplier                       Supplier                      @relation(fields: [supplier_id], references: [id])
  inventory_batches              InventoryBatch[]
  inventory_movements            InventoryMovement[]
  recipes                        Recipe[]
  waste_logs                     WasteLog[]
  purchase_order_items           PurchaseOrderItem[]
  supplier_lead_times            SupplierLeadTime[]
  demand_forecasts               DemandForecast[]
  replenishment_recommendations  ReplenishmentRecommendation[]

  @@unique([hotel_id, sku_code])
  @@map("skus")
}

model InventoryBatch {
  id                 String   @id @default(uuid())
  sku_id             String
  received_quantity  Decimal  @db.Decimal(12, 3)
  remaining_quantity Decimal  @db.Decimal(12, 3)
  received_date      DateTime @db.Date
  expiry_date        DateTime @db.Date
  unit_cost          Decimal  @db.Decimal(12, 2)
  created_at         DateTime @default(now()) @db.Timestamptz
  sku                Sku      @relation(fields: [sku_id], references: [id])

  @@map("inventory_batches")
}

model InventoryMovement {
  id             String        @id @default(uuid())
  sku_id         String
  movement_type  MovementType
  quantity       Decimal       @db.Decimal(12, 3)
  reference_type ReferenceType
  reference_id   String?
  movement_date  DateTime      @db.Date
  notes          String?       @db.Text
  created_at     DateTime      @default(now()) @db.Timestamptz
  sku            Sku           @relation(fields: [sku_id], references: [id])

  @@map("inventory_movements")
}

model MenuItem {
  id               String           @id @default(uuid())
  hotel_id         String
  name             String           @db.VarChar(150)
  category         String?          @db.VarChar(100)
  selling_price    Decimal          @db.Decimal(12, 2)
  is_active        Boolean          @default(true)
  created_at       DateTime         @default(now()) @db.Timestamptz
  updated_at       DateTime         @updatedAt @db.Timestamptz
  hotel            Hotel            @relation(fields: [hotel_id], references: [id])
  recipes          Recipe[]
  pos_transactions PosTransaction[]

  @@map("menu_items")
}

model Recipe {
  id                   String   @id @default(uuid())
  menu_item_id         String
  sku_id               String
  quantity_per_serving Decimal  @db.Decimal(12, 3)
  unit                 String   @db.VarChar(30)
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @updatedAt @db.Timestamptz
  menu_item            MenuItem @relation(fields: [menu_item_id], references: [id])
  sku                  Sku      @relation(fields: [sku_id], references: [id])

  @@unique([menu_item_id, sku_id])
  @@map("recipes")
}

model PosTransaction {
  id               String    @id @default(uuid())
  hotel_id         String
  menu_item_id     String
  quantity_sold    Int
  transaction_date DateTime  @db.Date
  meal_period      String?   @db.VarChar(30)
  created_at       DateTime  @default(now()) @db.Timestamptz
  hotel            Hotel     @relation(fields: [hotel_id], references: [id])
  menu_item        MenuItem  @relation(fields: [menu_item_id], references: [id])

  @@map("pos_transactions")
}

model OccupancyRecord {
  id                          String   @id @default(uuid())
  hotel_id                    String
  record_date                 DateTime @db.Date
  occupied_rooms              Int
  occupancy_rate              Decimal  @db.Decimal(5, 2)
  estimated_restaurant_visits Int
  created_at                  DateTime @default(now()) @db.Timestamptz
  hotel                       Hotel    @relation(fields: [hotel_id], references: [id])

  @@map("occupancy_records")
}

model WasteLog {
  id             String      @id @default(uuid())
  sku_id         String
  quantity       Decimal     @db.Decimal(12, 3)
  unit           String      @db.VarChar(30)
  waste_reason   WasteReason
  estimated_cost Decimal     @db.Decimal(12, 2)
  waste_date     DateTime    @db.Date
  notes          String?     @db.Text
  created_at     DateTime    @default(now()) @db.Timestamptz
  sku            Sku         @relation(fields: [sku_id], references: [id])

  @@map("waste_logs")
}

model PurchaseOrder {
  id                     String              @id @default(uuid())
  hotel_id               String
  supplier_id            String
  status                 PurchaseOrderStatus
  order_date             DateTime            @db.Date
  expected_delivery_date DateTime            @db.Date
  total_cost             Decimal             @db.Decimal(14, 2)
  created_at             DateTime            @default(now()) @db.Timestamptz
  updated_at             DateTime            @updatedAt @db.Timestamptz
  hotel                  Hotel               @relation(fields: [hotel_id], references: [id])
  supplier               Supplier            @relation(fields: [supplier_id], references: [id])
  purchase_order_items   PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String        @id @default(uuid())
  purchase_order_id String
  sku_id            String
  ordered_quantity  Decimal       @db.Decimal(12, 3)
  unit_cost         Decimal       @db.Decimal(12, 2)
  discount_rate     Decimal?      @db.Decimal(5, 2)
  created_at        DateTime      @default(now()) @db.Timestamptz
  purchase_order    PurchaseOrder @relation(fields: [purchase_order_id], references: [id])
  sku               Sku           @relation(fields: [sku_id], references: [id])

  @@map("purchase_order_items")
}

model SupplierLeadTime {
  id                         String   @id @default(uuid())
  supplier_id                String
  sku_id                     String
  average_lead_time_days     Int
  lead_time_variability_days Int
  created_at                 DateTime @default(now()) @db.Timestamptz
  updated_at                 DateTime @updatedAt @db.Timestamptz
  supplier                   Supplier @relation(fields: [supplier_id], references: [id])
  sku                        Sku      @relation(fields: [sku_id], references: [id])

  @@unique([supplier_id, sku_id])
  @@map("supplier_lead_times")
}

model DemandForecast {
  id                    String   @id @default(uuid())
  sku_id                String
  forecast_period_start DateTime @db.Date
  forecast_period_end   DateTime @db.Date
  average_daily_demand  Decimal  @db.Decimal(12, 3)
  demand_variability    Decimal  @db.Decimal(12, 3)
  seasonality_factor    Decimal  @db.Decimal(6, 3)
  created_at            DateTime @default(now()) @db.Timestamptz
  sku                   Sku      @relation(fields: [sku_id], references: [id])

  @@unique([sku_id, forecast_period_start, forecast_period_end])
  @@map("demand_forecasts")
}

model ReplenishmentRecommendation {
  id                      String    @id @default(uuid())
  sku_id                  String
  recommendation_date     DateTime  @db.Date
  current_stock           Decimal   @db.Decimal(12, 3)
  reorder_point           Decimal   @db.Decimal(12, 3)
  recommended_quantity    Decimal   @db.Decimal(12, 3)
  eoq_value               Decimal   @db.Decimal(12, 3)
  estimated_days_of_cover Decimal   @db.Decimal(8, 2)
  risk_level              RiskLevel
  explanation             String?   @db.Text
  created_at              DateTime  @default(now()) @db.Timestamptz
  sku                     Sku       @relation(fields: [sku_id], references: [id])

  @@map("replenishment_recommendations")
}

model SimulationRun {
  id               String       @id @default(uuid())
  hotel_id         String
  name             String       @db.VarChar(150)
  scenario_type    ScenarioType
  input_parameters Json
  result_summary   Json
  created_at       DateTime     @default(now()) @db.Timestamptz
  hotel            Hotel        @relation(fields: [hotel_id], references: [id])

  @@map("simulation_runs")
}
